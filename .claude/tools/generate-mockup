<body>
<!-- Workbench: Draw Canvas -->
<canvas class="draw-canvas" id="drawCanvas"></canvas>

<!-- Workbench: Controls Bar -->
<div class="controls-bar">
    <label>Device</label>
    <select id="deviceSelect" onchange="setDevice(this.value)">
        <option value="iphone">iPhone 15 Pro (393x852)</option>
        <option value="ipad">iPad Pro 11" (834x1194)</option>
        <option value="watch">Apple Watch (198x242)</option>
