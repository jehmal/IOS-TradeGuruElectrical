<script>
// ===== App Config =====
const APP_NAME = '{name}';

// ===== State =====
let currentDevice = 'iphone';
let currentComponent = 'empty-state';
let isDark = false;

// ===== Helpers =====
function esc(s) {{
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\\n/g,'<br>');
}}

// ===== Block Renderer =====
function htmlBlock(block) {{
    switch(block.type) {{
        case 'text':
            return `<div class="block-text">${{esc(block.content)}}</div>`;
        case 'heading':
            const hl = block.level || 2;
            return `<div class="block-heading h${{hl}}">${{esc(block.content)}}</div>`;
        case 'stepList':
        case 'step_list':
            return `<div class="block-step-list">
                ${{block.title?`<div class="step-title">${{esc(block.title)}}</div>`:''}}
                ${{(block.steps||[]).map((s,i) => `<div class="step-item">
                    <div class="step-num">${{i+1}}</div>
                    <div class="step-body"><div class="step-text">${{esc(typeof s === 'string' ? s : s.instruction || s.text || '')}}</div></div>
                </div>`).join('')}}
            </div>`;
        case 'warning':
            return `<div class="block-warning">
                <div class="warning-icon">&#9888;&#65039;</div>
                <div class="warning-text">${{esc(block.content)}}</div>
            </div>`;
        case 'code':
            return `<div class="block-code">
                ${{block.language?`<div class="code-lang">${{esc(block.language)}}</div>`:''}}
                <div class="code-content">${{esc(block.content)}}</div>
            </div>`;
        case 'callout':
            const cStyle = block.style || 'info';
            const cIcons = {{tip:'\\u2705', info:'\\u2139\\uFE0F', important:'\\u26A0\\uFE0F'}};
            return `<div class="block-callout callout-${{cStyle}}">
                <div class="callout-icon">${{cIcons[cStyle]||''}}</div>
                <div class="callout-text">${{esc(block.content)}}</div>
            </div>`;
        case 'table':
            return `<div class="block-table"><table>
                <thead><tr>${{(block.headers||[]).map(h=>`<th>${{esc(h)}}</th>`).join('')}}</tr></thead>
                <tbody>${{(block.rows||[]).map(r=>`<tr>${{r.map(c=>`<td>${{esc(c)}}</td>`).join('')}}</tr>`).join('')}}</tbody>
            </table></div>`;
        case 'partsList':
        case 'parts_list':
            return `<div class="block-parts">
                ${{block.title?`<div class="parts-title">${{esc(block.title)}}</div>`:''}}
                <table>
                    <thead><tr><th>Item</th><th>Specification</th><th>Qty</th></tr></thead>
                    <tbody>${{(block.items||[]).map(it=>`<tr><td>${{esc(it.name)}}</td><td>${{esc(it.spec)}}</td><td>${{it.qty}}</td></tr>`).join('')}}</tbody>
                </table>
            </div>`;
        case 'regulation':
            return `<div class="block-regulation">
                <div class="reg-code">${{esc(block.code)}}</div>
                <div class="reg-clause">${{esc(block.clause)}}</div>
                <div class="reg-summary">${{esc(block.summary||block.content)}}</div>
            </div>`;
        default:
            return `<div class="block-text">${{esc(block.content||JSON.stringify(block))}}</div>`;
    }}
}}

// ===== Message Renderer =====
function htmlMessage(msg) {{
    if (msg.role === 'user') {{
        return `<div class="msg-row user"><div class="msg-bubble-user">${{msg.blocks.map(htmlBlock).join('')}}</div></div>`;
    }}
    return `<div class="msg-row"><div class="msg-bubble-assistant">${{msg.blocks.map(htmlBlock).join('')}}</div></div>`;
}}

// ===== Nav Bar =====
function htmlNavBar() {{
    return `<div class="nav-bar"><div class="nav-title">${{APP_NAME}}</div></div>`;
}}

// ===== Render Isolated Component =====
function renderIsolated(html) {{
    return `${{htmlNavBar()}}<div class="isolated-component"><div style="width:100%">${{html}}</div></div>`;
}}

// ===== Main Render =====
function render() {{
    const sc = document.getElementById('screenContent');
    switch(currentComponent) {{
        case 'empty-state':
            sc.innerHTML = `${{htmlNavBar()}}<div class="empty-state"><div class="empty-state-title">${{APP_NAME}}</div><div class="empty-state-sub">Select a component to preview</div></div>`;
            break;
        default:
            sc.innerHTML = `${{htmlNavBar()}}<div class="empty-state"><div class="empty-state-sub">Component "${{currentComponent}}" not found</div></div>`;
    }}
}}

// ===== Device / Theme / Component =====
function setDevice(type) {{
    currentDevice = type;
    const frame = document.getElementById('deviceFrame');
    frame.className = 'device-frame ' + type;
    const labels = {{ iphone:'iPhone 15 Pro \\u2014 393 \\u00D7 852', ipad:'iPad Pro 11" \\u2014 834 \\u00D7 1194 (scaled 60%)', watch:'Apple Watch \\u2014 198 \\u00D7 242' }};
    document.getElementById('deviceLabel').innerHTML = labels[type] || '';
    render();
}}

function setComponent(comp) {{
    currentComponent = comp;
    render();
}}

function toggleTheme() {{
    isDark = !isDark;
    document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
    document.getElementById('themeBtn').innerHTML = isDark ? '&#9788; Light' : '&#9790; Dark';
    document.getElementById('themeBtn').classList.toggle('active', isDark);
    render();
}}

// ===== Pen / Draw =====
const drawCanvas = document.getElementById('drawCanvas');
const drawCtx = drawCanvas.getContext('2d');
let penActive = false, eraserMode = false, isDrawing = false;
let penColor = '#e94560', penSize = 3;

function resizeCanvas() {{
    drawCanvas.width = window.innerWidth;
    drawCanvas.height = window.innerHeight;
}}
window.addEventListener('resize', resizeCanvas);
resizeCanvas();

drawCanvas.addEventListener('mousedown', (e) => {{ isDrawing = true; drawCtx.beginPath(); drawCtx.moveTo(e.clientX, e.clientY); }});
drawCanvas.addEventListener('mousemove', (e) => {{
    if (!isDrawing) return;
    if (eraserMode) {{
        drawCtx.globalCompositeOperation = 'destination-out';
        drawCtx.lineWidth = penSize * 4;
    }} else {{
        drawCtx.globalCompositeOperation = 'source-over';
        drawCtx.lineWidth = penSize;
    }}
    drawCtx.strokeStyle = penColor;
    drawCtx.lineCap = 'round';
    drawCtx.lineJoin = 'round';
    drawCtx.lineTo(e.clientX, e.clientY);
    drawCtx.stroke();
}});
drawCanvas.addEventListener('mouseup', () => {{ isDrawing = false; }});
drawCanvas.addEventListener('mouseleave', () => {{ isDrawing = false; }});

function togglePen() {{
    penActive = !penActive;
    eraserMode = false;
    drawCanvas.classList.toggle('active', penActive);
    drawCanvas.classList.remove('eraser-mode');
    document.getElementById('penBtn').classList.toggle('active', penActive);
    document.querySelector('.pen-toolbar').classList.toggle('visible', penActive);
}}

function toggleEraser() {{
    eraserMode = !eraserMode;
    drawCanvas.classList.toggle('eraser-mode', eraserMode);
    document.getElementById('eraserBtn').classList.toggle('active', eraserMode);
}}

function clearDrawing() {{
    drawCtx.clearRect(0, 0, drawCanvas.width, drawCanvas.height);
}}

function setPenColor(color, btn) {{
    penColor = color;
    eraserMode = false;
    drawCanvas.classList.remove('eraser-mode');
    document.querySelectorAll('.pen-toolbar .color-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
}}

function setPenSize(size, btn) {{
    penSize = size;
    document.querySelectorAll('.pen-toolbar .size-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
}}

// ===== Notes Panel =====
let notes = JSON.parse(localStorage.getItem('{storage_key}') || '[]');
let notesVisible = false;

function toggleNotes() {{
    notesVisible = !notesVisible;
    document.getElementById('notesPanel').classList.toggle('visible', notesVisible);
    document.getElementById('notesBtn').classList.toggle('active', notesVisible);
    renderNotes();
}}

function renderNotes() {{
    const list = document.getElementById('notesList');
    if (!list) return;
    list.innerHTML = notes.map((n, i) =>
        `<div class="note-item">
            <button class="note-delete" onclick="deleteNote(${{i}})">\\u00D7</button>
            ${{n.text}}
            <div class="note-time">${{n.time}}</div>
        </div>`
    ).join('') || '<div style="color:#666;padding:20px;text-align:center">No notes yet</div>';
}}

function addNote() {{
    const input = document.getElementById('noteInput');
    if (!input.value.trim()) return;
    notes.unshift({{ text: input.value.trim(), time: new Date().toLocaleString() }});
    localStorage.setItem('{storage_key}', JSON.stringify(notes));
    input.value = '';
    renderNotes();
}}

function deleteNote(i) {{
    notes.splice(i, 1);
    localStorage.setItem('{storage_key}', JSON.stringify(notes));
    renderNotes();
}}

document.getElementById('noteInput')?.addEventListener('keydown', (e) => {{
    if (e.key === 'Enter') addNote();
}});

// Initial render
render();
