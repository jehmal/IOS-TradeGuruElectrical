#!/usr/bin/env python3
"""
Generate a blank iOS app mockup HTML workbench.

Usage:
    python3 generate-mockup --name "MyApp" --accent "#3B82F6" --out ~/Desktop/myapp-preview.html
    python3 generate-mockup --name "MyApp"  # outputs to ./preview/myapp-mockup.html

Features included:
    - iPhone 15 Pro / iPad Pro 11" / Apple Watch device frames
    - Light/Dark mode toggle
    - Component picker dropdown (empty, ready to populate)
    - Pen/draw overlay tool with color picker and eraser
    - Notes panel (persists to localStorage)
    - Dynamic Island, status bar, home indicator
    - CSS variable theming system
    - Block rendering system (text, heading, stepList, warning, code, callout, table, partsList, regulation)
"""

import argparse
import os
import sys
import re


def generate(name: str, accent: str, out_path: str):
    safe_name = re.sub(r'[^a-zA-Z0-9]', '', name).lower()
    storage_key = f'{safe_name}_workbench_notes'

    html = f'''<!DOCTYPE html>
