    <button id="themeBtn" onclick="toggleTheme()">&#9790; Dark</button>
    <div class="sep"></div>
    <span style="color:#666;font-size:10px;letter-spacing:0.5px;text-transform:uppercase">Workbench</span>
    <button id="penBtn" onclick="togglePen()">&#9998; Pen</button>
