# TradeGuru CLI Toolkit — Environment Variables
# Copy this file to .env and fill in your keys
# cp .env.example .env

# =============================================================================
# IMAGE GENERATION (Required for image/icon/screenshot tools)
# =============================================================================

# OpenAI API key — used for DALL-E image generation
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=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

# Image generation model (optional, default: gpt-image-1)
# Options: gpt-image-1, gpt-image-1.5, gpt-image-1-mini, dall-e-3, dall-e-2
# IMAGE_GEN_MODEL=gpt-image-1

# Image background mode (optional, default: auto) — gpt-image models only
# Options: transparent, opaque, auto
# IMAGE_GEN_BACKGROUND=auto

# OpenAI API base URL (optional, for proxies or Azure OpenAI)
# OPENAI_API_BASE=https://api.openai.com/v1

# =============================================================================
# REVENUECAT (Required for in-app purchase tools)
# =============================================================================

# RevenueCat API keys — get from RevenueCat dashboard
# REVENUECAT_API_KEY=
# REVENUECAT_TEST_API_KEY=

# =============================================================================
# APP STORE CONNECT (Required for publishing tools)
# =============================================================================

# Apple Developer Team ID
# APPLE_TEAM_ID=

# App Store Connect API Key (p8 format)
# ASC_API_KEY_ID=
# ASC_API_KEY_ISSUER_ID=
# ASC_API_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_XXXXXX.p8
