{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oandp-02-03-04-plan",
  "title": "Step 02_03_04: Plan (Collapsed)",
  "description": "Collapsed planning manifest for TRIVIAL profile. Combines decompose, system select, and design.",
  "allOf": [{ "$ref": "base.schema.json" }],
  "properties": {
    "step_id": { "const": "02_03_04" },
    "step_name": { "const": "PLAN" },
    "input_file": { "const": "01a_workflow_resolution.json" },
    "payload": {
      "type": "object",
      "required": ["decomposition", "system_selection", "design"],
      "properties": {
        "decomposition": {
          "type": "object",
          "required": ["workstreams"],
          "properties": {
            "workstreams": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "name", "acceptance_criteria"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
                }
              }
            },
            "critical_path": { "type": "array", "items": { "type": "string" } }
          }
        },
        "system_selection": {
          "type": "object",
          "required": ["primary_system", "selection_reason"],
          "properties": {
            "primary_system": { "enum": ["DMADV", "DMAIC"] },
            "selection_reason": { "type": "string", "minLength": 1 }
          }
        },
        "design": {
          "type": "object",
          "required": ["solution_summary", "editable_surfaces", "immutable_surfaces", "test_plan"],
          "properties": {
            "solution_summary": { "type": "string", "minLength": 1 },
            "editable_surfaces": { "type": "array", "items": { "type": "string" } },
            "immutable_surfaces": { "type": "array", "items": { "type": "string" } },
            "test_plan": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["workstream_count", "design_completeness_score"],
      "properties": {
        "workstream_count": { "type": "integer", "minimum": 1 },
        "design_completeness_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
