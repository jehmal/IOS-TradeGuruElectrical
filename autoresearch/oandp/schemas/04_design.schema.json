{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oandp-04-design",
  "title": "Step 04: Design (Plan Solution)",
  "allOf": [{ "$ref": "base.schema.json" }],
  "properties": {
    "step_id": { "const": "04" },
    "step_name": { "const": "DESIGN_PLAN" },
    "input_file": { "const": "03_system_select.json" },
    "payload": {
      "type": "object",
      "required": ["solution_architecture", "editable_surfaces", "immutable_surfaces", "test_plan", "hil_checkpoints"],
      "properties": {
        "solution_architecture": { "type": "string", "minLength": 1 },
        "interfaces": { "type": "array", "items": { "type": "string" } },
        "editable_surfaces": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "immutable_surfaces": { "type": "array", "items": { "type": "string" } },
        "artifact_plan": { "type": "array", "items": { "type": "string" } },
        "test_plan": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "handoff_plan": { "type": "array", "items": { "type": "string" } },
        "failure_modes": { "type": "array", "items": { "type": "string" } },
        "hil_checkpoints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["design_completeness_score", "test_coverage_planned"],
      "properties": {
        "design_completeness_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "interface_count": { "type": "integer", "minimum": 0 },
        "test_coverage_planned": { "type": "number", "minimum": 0, "maximum": 1 },
        "unresolved_risk_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
