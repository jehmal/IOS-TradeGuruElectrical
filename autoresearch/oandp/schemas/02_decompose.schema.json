{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oandp-02-decompose",
  "title": "Step 02: Decompose (Break Down)",
  "allOf": [{ "$ref": "base.schema.json" }],
  "properties": {
    "step_id": { "const": "02" },
    "step_name": { "const": "DECOMPOSE" },
    "input_file": { "const": "01a_workflow_resolution.json" },
    "payload": {
      "type": "object",
      "required": ["workstreams", "critical_path", "required_roles", "estimated_complexity"],
      "properties": {
        "workstreams": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "description", "dependencies", "acceptance_criteria"],
            "properties": {
              "id": { "type": "string", "pattern": "^WS-\\d+$" },
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "owner_role": { "type": "string" },
              "dependencies": { "type": "array", "items": { "type": "string" } },
              "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            }
          }
        },
        "critical_path": { "type": "array", "items": { "type": "string" } },
        "required_roles": { "type": "array", "items": { "type": "string" } },
        "estimated_complexity": { "enum": ["low", "medium", "high"] },
        "task_graph_summary": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["workstream_count", "dependency_count", "acceptance_criteria_count"],
      "properties": {
        "workstream_count": { "type": "integer", "minimum": 1 },
        "dependency_count": { "type": "integer", "minimum": 0 },
        "acceptance_criteria_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
