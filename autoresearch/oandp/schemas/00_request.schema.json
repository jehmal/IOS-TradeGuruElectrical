{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oandp-00-request",
  "title": "Step 00: Request Normalization",
  "allOf": [{ "$ref": "base.schema.json" }],
  "properties": {
    "step_id": { "const": "00" },
    "step_name": { "const": "REQUEST_NORMALIZATION" },
    "input_file": { "const": "request.md" },
    "payload": {
      "type": "object",
      "required": ["request_text", "goal", "constraints", "desired_outputs", "priority", "task_class"],
      "properties": {
        "request_text": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "desired_outputs": { "type": "array", "items": { "type": "string" } },
        "priority": { "enum": ["low", "medium", "high", "critical"] },
        "deadline": { "type": "string" },
        "stakeholders": { "type": "array", "items": { "type": "string" } },
        "task_class": { "enum": ["build", "optimize", "research", "ops", "content", "bug_fix", "doc_update", "config_tweak", "integration", "deployment", "other"] }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["ambiguity_count", "missing_field_count", "normalization_confidence"],
      "properties": {
        "ambiguity_count": { "type": "integer", "minimum": 0 },
        "missing_field_count": { "type": "integer", "minimum": 0 },
        "normalization_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
